# ── 환경 변수 / 시크릿 ───────────────────────────────────────
# .env 는 절대 커밋하지 않습니다. 예시는 .env.example 로 대체.
.env
.env.*
!.env.example

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# ── 가상환경 (uv 관리) ─────────────────────────────────────
.venv/
venv/
env/

# ── 플랫폼 / IDE ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── 로그 / 임시 ─────────────────────────────────────────────
*.log
*.tmp
_regen_*.py
